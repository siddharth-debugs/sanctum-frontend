# Sanctum frontend environment variables
# Copy to .env.local and fill in real values. DO NOT commit .env.local.

# Base URL of the separate Express API (includes the /api/v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Cloudinary cloud name for signed media uploads (browser -> Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
